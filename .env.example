# Copy to .env and fill in real values. NEVER commit the real .env.
GROQ_API_KEY=your_groq_api_key_here

# Optional tuning (sensible defaults are built in):
# GROQ_MODEL=llama-3.3-70b-versatile
# VIDEO_SECONDS=60
# DRY_RUN=1            # build the video but skip the YouTube upload

# Google OAuth is configured via files, NOT env vars. These are gitignored and
# must be provided locally (never committed):
#   client_secrets.json  -> download from Google Cloud Console (OAuth desktop client)
#   token.json           -> generated automatically on first OAuth sign-in
